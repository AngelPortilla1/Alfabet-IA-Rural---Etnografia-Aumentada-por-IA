# Variables de entorno globales para el despliegue con Docker Compose

# Para el frontend
# Modifica esta URL con la IP de tu servidor si se expone a internet, ej. http://203.0.113.5:8000
VITE_API_URL=http://localhost:8000

# Para el backend
# --- CONFIGURACIÓN PARA OLLAMA (Local) ---
# ALFABETIA_LLM_PROVIDER=ollama
# ALFABETIA_OLLAMA_MODEL=qwen3:4b
# En Linux, usualmente se usa http://172.17.0.1:11434 si host.docker.internal no resuelve automáticamente.
# ALFABETIA_OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- CONFIGURACIÓN PARA DEEPSEEK / OPENAI (Cloud) ---
ALFABETIA_LLM_PROVIDER=openai
ALFABETIA_OPENAI_MODEL=deepseek-chat
ALFABETIA_OPENAI_BASE_URL=https://api.deepseek.com/v1
ALFABETIA_OPENAI_API_KEY=tu_api_key_de_deepseek

# Configuración de CORS
# Puedes limitar esto a tu dominio ej. http://midominio.com
ALFABETIA_CORS_ORIGINS=*
